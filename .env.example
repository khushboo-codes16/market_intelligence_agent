# ============================================================
# AI-Powered Business & Market Intelligence Agent
# Environment Configuration
# ============================================================

# --- Groq API ---
GROQ_API_KEY=your_groq_api_key_here

# --- LLM Model Configuration ---
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096
LLM_MAX_CONCURRENT=2

# --- ChromaDB Configuration ---
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=market_intel

# --- Embedding Model ---
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Web Scraping ---
REQUEST_TIMEOUT=15
REQUEST_DELAY=1.5
MAX_PAGES_PER_DOMAIN=5
USER_AGENT=Mozilla/5.0 (compatible; MarketIntelBot/1.0)

# --- RAG Settings ---
CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K_RESULTS=5

# --- Lead Scoring ---
LEAD_SCORE_HIRING_WEIGHT=25
LEAD_SCORE_FUNDING_WEIGHT=30
LEAD_SCORE_LAUNCH_WEIGHT=20
LEAD_SCORE_EXPANSION_WEIGHT=15
LEAD_SCORE_PARTNERSHIP_WEIGHT=10

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=./data/app.log

# --- Reports ---
REPORTS_DIR=./reports
